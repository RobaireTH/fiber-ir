# API
PORT=8787
FIR_STORE_FILE=.data/fiber-ir-incidents.json
FIR_BODY_LIMIT_BYTES=1048576

# Set this when the dashboard is hosted on a different origin from the API.
# Use a comma-separated list for multiple allowed origins.
FIR_CORS_ORIGIN=http://localhost:5173

# Set this when serving the built dashboard from the API process.
FIR_DASHBOARD_DIST=dashboard/dist

# Set this when building the dashboard for a separately hosted API.
# Leave empty for same-origin API calls.
VITE_FIR_API_BASE_URL=

# Optional read-only Fiber JSON-RPC smoke/probe.
FIBER_RPC_URL=http://127.0.0.1:8227
# FIBER_RPC_AUTH_HEADER=Bearer replace-me
